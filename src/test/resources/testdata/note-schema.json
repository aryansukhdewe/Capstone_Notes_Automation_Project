{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Notes API Response Schema",
  "_comment": "WHY JSON SCHEMA VALIDATION: Schema validation catches contract breaks early. If the API team changes the response structure, our tests immediately flag it even if the data looks correct. This is a key practice in contract testing.",

  "type": "object",
  "required": ["success", "status", "message", "data"],
  "properties": {
    "success": {
      "type": "boolean",
      "description": "Indicates if the API request was successful"
    },
    "status": {
      "type": "integer",
      "description": "HTTP status code echoed in body"
    },
    "message": {
      "type": "string",
      "description": "Human-readable response message"
    },
    "data": {
      "type": "object",
      "required": ["id", "title", "description", "category", "completed", "user_id"],
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "category": {
          "type": "string",
          "enum": ["Home", "Work", "Personal"]
        },
        "completed": { "type": "boolean" },
        "user_id": { "type": "string" },
        "created_at": { "type": "string" },
        "updated_at": { "type": "string" }
      }
    }
  }
}
